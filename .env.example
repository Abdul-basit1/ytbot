# UpperCut YouTube Automation — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env

# AI
OPENAI_API_KEY=sk-your-openai-key-here

# Stock Footage
PEXELS_API_KEY=your-pexels-api-key
PIXABAY_API_KEY=your-pixabay-api-key

# KiddoWorld — fal.ai for cartoon animation
FAL_API_KEY=your-fal-api-key

# YouTube OAuth (path to downloaded JSON file)
YOUTUBE_CLIENT_SECRETS=client_secrets.json

# Email Alerts (Gmail App Password — https://myaccount.google.com/apppasswords)
ALERT_EMAIL=your@email.com
SMTP_EMAIL=your@gmail.com
SMTP_PASSWORD=your-app-password

# Dashboard
DASHBOARD_SECRET_KEY=change-this-to-a-random-string
DASHBOARD_PORT=8080
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your_strong_password_here

# VPS
VPS_IP=your-vps-ip
